PORT=3100
COLLECTOR_URL=http://localhost:3000/collect
SENSOR_ID=mock-1
SENSOR_INTERVAL_MS=1000
SENSOR_ADAPTER=mock
# collector: normalized values 직접 전송
# raw: modbus RTU raw frame 생성용 (modbus-driver가 /raw/frame polling)
SENSOR_OUTPUT_MODE=raw
# true면 mock-sensor -> collector 직송을 차단하고 raw->driver 파이프라인만 허용
ENFORCE_DRIVER_PIPELINE=true
